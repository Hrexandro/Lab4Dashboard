<UserControl x:Class="TextWidget.TextWidgetView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="200" Width="300">
    <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="5">
        <StackPanel>
            <TextBlock Text="Analizator tekstu"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Liczba znaków:" FontWeight="Bold"/>
            <TextBlock x:Name="CharactersTextBlock"
                       Text="0"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Liczba słów:" FontWeight="Bold"/>
            <TextBlock x:Name="WordsTextBlock"
                       Text="0"/>
        </StackPanel>
    </Border>
</UserControl>